{
    "name": "aiwaf-js",
    "version": "0.1.0",
    "description": "Adaptive Web Application Firewall middleware for Node.js (Express, Fastify, Hapi, Next.js)",
    "main": "index.js",
    "files": [
        "index.js",
        "bin/",
        "lib/",
        "resources/",
        "utils/",
        "train.js",
        "README.md",
        "INSTALLATION.md",
        "LICENSE"
    ],
    "bin": {
        "aiwaf": "bin/aiwaf.js"
    },
    "scripts": {
        "retrain": "AIWAF_LOG_PATH=/var/log/nginx/access.log npm run train",
        "train": "node train.js",
        "test": "jest --runInBand",
        "aiwaf": "node bin/aiwaf.js",
        "perf:wasm": "node test/perf-wasm.js",
        "test:wasm-real": "node test/wasm-real.js"
    },
    "dependencies": {
        "aiwaf-wasm": "^0.1.6",
        "express": "^4.21.2",
        "glob": "^8.1.0",
        "jest": "^29.7.0",
        "knex": "^2.4.2",
        "node-cache": "^5.1.2",
        "redis": "^4.6.5",
        "sqlite3": "^6.0.1",
        "supertest": "^7.1.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
    "fastify": "^4.29.1",
    "@hapi/hapi": "^21.3.12",
    "koa": "^2.15.4",
    "koa-bodyparser": "^4.4.1",
    "@nestjs/common": "^10.4.2",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1"
    },
    "jest": {
        "globalTeardown": "<rootDir>/test/jest.teardown.js",
        "forceExit": true
    },
    "optionalDependencies": {
        "maxmind": "^4.3.0"
    },
    "overrides": {
        "body-parser": "^1.20.3",
        "qs": "^6.14.1",
        "path-to-regexp": "^0.1.13",
        "brace-expansion": "^1.1.13",
        "minimatch": "^5.1.8",
        "picomatch": "^2.3.2",
        "form-data": "^4.0.4",
        "js-yaml": "^3.14.2",
        "lodash": "^4.17.24",
        "tar-fs": "^2.1.4"
    },
    "keywords": [
        "waf",
        "firewall",
        "security",
        "express",
        "nodejs",
        "middleware",
        "ml"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/aiwaf-project/aiwaf-js"
    },
    "author": "Aayush Gauba",
    "license": "MIT"
}
